{
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "site": "godseye-dashboard",
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      }
    ]
  }
}
